# WorkBuddy RAG 记忆 - 配置
# 复制为 .env 后填入实际值

# Embedding 模型（阶段 1 默认）
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
EMBED_DEVICE=cpu
EMBED_NORMALIZE=true

# 索引存储路径
INDEX_DIR=./.index
DEDUP_THRESHOLD=0.92

# 检索默认参数
TOP_K=5
RRF_K=60

# ============================================================
# 网络策略（阶段 1.5 强化）
# ============================================================
# HF_HUB_OFFLINE: 1=强制本地缓存（推荐），0=允许联网
# 默认已在 src/embedder.py 锁定为 1，无需在此设
# 仅在需要下载/更新模型时临时设为 0：
#   set HF_HUB_OFFLINE=0 && python download_bge_v2.py
HF_HUB_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1

# ============================================================
# 真实记忆源（可选，scripts/ingest_wb_memory.py 用）
# ============================================================
# 扫描这些目录并入库（用 ; 分隔多个）
WB_MEMORY_DIRS=~/.workbuddy/memory;./.workbuddy/memory
# 跳过匹配以下模式的文件（glob）
WB_MEMORY_IGNORE=*.bak;*.tmp.*;*~
